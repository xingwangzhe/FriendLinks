---
import "../styles/starwind.css";
import "../css/base.css";
import "../css/topbar.css";
import { Button } from "@/components/starwind/button";
import { Spinner } from "@/components/starwind/spinner";
import { Dialog, DialogContent, DialogTitle, DialogHeader, DialogTrigger } from "@/components/starwind/dialog";
export const prerender = true;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/StreamlinePlumpColorWebFlat.svg"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>博客宇宙</title>
    <meta name="description" content="探索浩瀚的博客宇宙，寻找彼此之间的联系" />
    <script is:inline>
      function initTheme() {
        const theme = localStorage.getItem("colorTheme");
        if (!theme) {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } else if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      }
      initTheme();
      document.addEventListener("astro:after-swap", initTheme);
    </script>
  </head>
  <body>
    <div class="topbar">
      <div class="title" style="font-weight:600; padding-left:6px;">
        <span>博客宇宙</span>
        <a
          class="github-link"
          href="https://github.com/xingwangzhe/FriendLinks"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open GitHub repository"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 16 16"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.19 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
        </a>
      </div>
      <div class="search">
        <input
          id="graph-search"
          type="text"
          placeholder="搜索站点名或域名 | 左键打开网站 | 右键聚焦节点"
          autocomplete="off"
        />
        <button id="graph-search-clear" class="search-clear" aria-label="清空搜索" title="清空搜索">✖</button>
        <div id="graph-search-results" class="results" role="listbox"></div>
      </div>
    </div>
    <div id="main"></div>

    <!-- 首屏加载蒙版 -->
    <div id="loading-overlay">
      <div class="loading-box">
        <Spinner class="size-10 text-[#4a9eff]" />
        <div class="loading-status">
          <span id="loading-text">正在探索博客宇宙...</span>
          <span id="loading-time" class="loading-time"></span>
        </div>
        <div class="loading-bar-track">
          <div id="loading-bar" class="loading-bar-fill"></div>
        </div>
      </div>
    </div>

    <div class="top-buttons">
      <button id="menu-toggle" class="top-button menu-toggle" aria-label="菜单" title="菜单">☰</button>
      <div class="top-buttons-group">
        <Button id="fly-toggle" variant="ghost" size="sm" aria-label="切换飞船模式">🚀 飞船模式</Button>
        <DialogTrigger for="about-dialog" asChild>
          <Button id="about-toggle" variant="ghost" size="sm" aria-label="关于项目">关于</Button>
        </DialogTrigger>
        <DialogTrigger for="stats-dialog" asChild>
          <Button id="stats-toggle" variant="ghost" size="sm" aria-label="查看统计信息">📊统计信息</Button>
        </DialogTrigger>
        <Button id="opacity-toggle" variant="ghost" size="sm" aria-label="控制面板">控制面板</Button>
        <Button id="path-toggle" variant="ghost" size="sm" aria-label="路径查找">🔗 路径查找</Button>
        <Button id="btn-random" variant="ghost" size="sm" aria-label="随机博客">🎲 随机博客</Button>
        <Button id="fullscreen-toggle" variant="ghost" size="sm" aria-label="全屏模式">⛶ 全屏模式</Button>
      </div>
    </div>

    <!-- 统计数据（构建时预埋，避免运行时 fetch） -->

    <!-- 统计弹窗 -->
    <Dialog id="stats-dialog">
      <DialogContent class="sm:max-w-3xl">
        <DialogHeader>
          <DialogTitle>📊 博客宇宙统计</DialogTitle>
        </DialogHeader>
        <div id="stats-content" class="space-y-4"></div>
      </DialogContent>
    </Dialog>

    <!-- 关于弹窗 -->
    <Dialog id="about-dialog">
      <DialogContent class="sm:max-w-2xl">
        <DialogHeader>
          <DialogTitle>关于博客宇宙</DialogTitle>
        </DialogHeader>
        <div class="space-y-5 text-sm">
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-lg border p-4">
              <h4 class="mb-2 font-semibold">🖱 操作</h4>
              <ul class="space-y-1 text-muted-foreground">
                <li><strong class="text-foreground">左键</strong> 打开网站</li>
                <li><strong class="text-foreground">右键</strong> 聚焦节点</li>
                <li><strong class="text-foreground">悬停</strong> 显示信息</li>
                <li><strong class="text-foreground">左键拖拽</strong> 旋转</li>
                <li><strong class="text-foreground">右键拖拽</strong> 平移</li>
                <li><strong class="text-foreground">滚轮</strong> 缩放</li>
              </ul>
            </div>
            <div class="rounded-lg border p-4">
              <h4 class="mb-2 font-semibold">🔍 搜索</h4>
              <ul class="space-y-1 text-muted-foreground">
                <li>输入站点名或域名实时搜索</li>
                <li>点击结果项可<strong class="text-foreground">打开网站</strong>或<strong class="text-foreground">聚焦节点</strong></li>
                <li><code class="rounded bg-muted px-1">?local=example.com</code> 按域名匹配</li>
                <li><code class="rounded bg-muted px-1">?local=https://example.com</code> 按完整 URL 匹配</li>
                <li><strong class="text-foreground">🎲 随机博客</strong> 按钮随机跳转</li>
              </ul>
            </div>
            <div class="rounded-lg border p-4">
              <h4 class="mb-2 font-semibold">✨ 聚焦效果</h4>
              <ul class="space-y-1 text-muted-foreground">
                <li>节点 <strong class="text-foreground">放大 1.5x</strong> + 调亮 60%</li>
                <li>亮金色粗管荧光连线</li>
                <li>邻居节点高亮 20%</li>
                <li>自动居中相机</li>
              </ul>
            </div>
            <div class="rounded-lg border p-4">
              <h4 class="mb-2 font-semibold">➕ 添加友链</h4>
              <p class="text-muted-foreground mb-2">在项目中新建 <code class="rounded bg-muted px-1">links/你的站点.yml</code>：</p>
              <pre class="rounded bg-muted p-2 text-xs overflow-x-auto"><code>name: 我的博客
url: https://example.com
links: /friends
friends:
  - name: 友人
    url: https://friend.com</code></pre>
            </div>
          </div>
          <div class="rounded-lg border p-4">
            <h4 class="mb-2 font-semibold">📋 要求</h4>
            <ul class="space-y-1 text-muted-foreground">
              <li>✅ 仅限<strong class="text-foreground">个人博客</strong>，有原创内容</li>
              <li>✅ 使用 <strong class="text-foreground">HTTPS</strong> 并可在国内访问</li>
              <li>✅ 友链页需包含本站信息</li>
            </ul>
          </div>
          <div class="flex gap-3 justify-end">
            <a href="https://github.com/xingwangzhe/FriendLinks" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs hover:bg-muted transition-colors">GitHub 仓库</a>
          </div>
        </div>
      </DialogContent>
    </Dialog>
    <!-- 路径查找底部栏 -->
    <div id="path-bar" class="path-bar">
      <div class="path-bar-row">
        <span class="path-bar-icon">🔗</span>
        <div class="path-search-wrap">
          <input
            id="path-search-from"
            type="text"
            placeholder="起点站点…"
            autocomplete="off"
          />
          <div id="path-results-from" class="path-results" role="listbox"></div>
        </div>
        <span class="path-arrow">→</span>
        <div class="path-search-wrap">
          <input
            id="path-search-to"
            type="text"
            placeholder="终点站点…"
            autocomplete="off"
          />
          <div id="path-results-to" class="path-results" role="listbox"></div>
        </div>
        <span id="path-step-indicator" class="path-step-info" style="display:none;"></span>
        <button id="path-prev-btn" class="path-nav-btn" disabled title="上一步">◀</button>
        <button id="path-next-btn" class="path-nav-btn" disabled title="下一步">▶</button>
        <button id="path-clear-btn" class="path-nav-btn path-clear-btn" title="清除路径" style="display:none;">✕</button>
        <button id="path-bar-close" class="path-nav-btn" title="关闭">−</button>
      </div>
      <div id="path-error" class="path-bar-error" style="display:none;"></div>
    </div>
    <style>
      /* 顶部按钮通用样式 */
      .top-button {
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--card-bg);
        color: var(--text-color);
        cursor: pointer;
        pointer-events: auto;
        font-size: 14px;
        white-space: nowrap;
        min-height: 36px;
      }
      .top-button:focus {
        outline: 2px solid
          color-mix(in srgb, var(--text-color) 20%, transparent);
      }

      /* 按钮容器 */
      .top-buttons {
        position: fixed;
        top: 12px;
        right: 12px;
        z-index: 60;
        display: flex;
        gap: 8px;
        align-items: flex-start;
        pointer-events: auto;
      }
      .menu-toggle {
        display: none;
        font-size: 18px;
        line-height: 1;
        min-width: 36px;
        min-height: 36px;
      }
      .top-buttons-group {
        display: flex;
        gap: 8px;
        pointer-events: auto;
      }

      /* 覆盖可能存在的 id 选择器定位（来自 topbar.css），确保按钮在容器内正常布局 */
      #stats-toggle {
        position: relative !important;
        top: auto !important;
        right: auto !important;
        z-index: 61 !important;
      }

      /* ── 移动端调整 ── */
      @media (max-width: 640px) {
        .top-buttons {
          top: 8px;
          right: 6px;
          flex-direction: column;
          align-items: flex-end;
          gap: 4px;
        }
        .menu-toggle {
          display: inline-block;
          min-width: 44px;
          min-height: 44px;
          font-size: 20px;
        }
        .top-buttons-group {
          display: none;
          flex-direction: column;
          gap: 4px;
          background: var(--card-bg);
          border: 1px solid var(--border);
          border-radius: 8px;
          padding: 6px;
          box-shadow: 0 4px 12px rgba(0,0,0,.15);
        }
        .top-buttons-group.open {
          display: flex;
        }
        .top-button {
          font-size: 13px;
          padding: 8px 12px;
          min-height: 44px;
        }
      }

      /* ── 平板端调整 (641-1024px) ── */
      @media (min-width: 641px) and (max-width: 1024px) {
        .top-buttons {
          top: 10px;
          right: 10px;
          gap: 6px;
        }
        .top-button {
          font-size: 13px;
          padding: 5px 8px;
        }
      }

      /* 首屏加载蒙版 */
      #loading-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg, #0f1115);
        transition: opacity 0.5s ease;
      }
      #loading-overlay.hidden {
        opacity: 0;
        pointer-events: none;
      }
      .loading-box {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
      }
      .loading-status {
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: center;
      }
      .loading-status span {
        font-size: 14px;
        color: var(--text-color);
        font-family: sans-serif;
      }
      .loading-time {
        font-size: 12px !important;
        color: var(--text-color) !important;
        font-variant-numeric: tabular-nums;
      }
      .loading-bar-track {
        width: 200px;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
      }
      .loading-bar-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #4a9eff, #7c5cfc);
        border-radius: 2px;
        transition: width 0.3s ease;
      }

      /* 路径底部栏 */
      #path-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: var(--card-bg);
        border-top: 1px solid var(--border);
        box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.12);
        padding: 8px 16px;
        transform: translateY(100%);
        transition: transform 0.3s ease;
      }
      #path-bar.show {
        transform: translateY(0);
      }
      .path-bar-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .path-bar-icon {
        font-size: 16px;
        flex-shrink: 0;
      }
      .path-arrow {
        color: var(--text-color);
        font-size: 14px;
        flex-shrink: 0;
      }
      .path-search-wrap {
        position: relative;
        flex: 1;
        min-width: 120px;
        max-width: 220px;
      }
      .path-search-wrap input {
        width: 100%;
        height: 32px;
        padding: 0 8px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--card-bg);
        color: var(--text-color);
        font-size: 13px;
        box-sizing: border-box;
      }
      .path-search-wrap input:focus {
        outline: 2px solid color-mix(in srgb, var(--text-color) 20%, transparent);
      }
      .path-results {
        position: absolute;
        bottom: 100%;
        left: 0;
        right: 0;
        max-height: 200px;
        overflow-y: auto;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        box-shadow: 0 -6px 18px rgba(0, 0, 0, 0.12);
        display: none;
        z-index: 10;
        margin-bottom: 4px;
      }
      .path-results .path-result-item {
        padding: 6px 10px;
        cursor: pointer;
        font-size: 13px;
        color: var(--text-color);
      }
      .path-results .path-result-item:hover {
        background: color-mix(in srgb, var(--card-bg) 92%, black 8%);
      }
      .path-result-item .path-result-name {
        font-weight: 600;
      }
      .path-result-item .path-result-url {
        font-size: 11px;
        color: var(--text-color);
        margin-top: 2px;
      }
      .path-step-info {
        font-size: 12px;
        color: var(--text-color);
        white-space: nowrap;
        flex-shrink: 0;
      }
      .path-nav-btn {
        height: 32px;
        padding: 0 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--card-bg);
        color: var(--text-color);
        cursor: pointer;
        font-size: 14px;
        flex-shrink: 0;
        white-space: nowrap;
      }
      .path-nav-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }
      .path-nav-btn:not(:disabled):hover {
        background: color-mix(in srgb, var(--card-bg) 92%, black 8%);
      }
      .path-clear-btn {
        color: #e74c3c;
        border-color: #e74c3c;
      }
      .path-clear-btn:hover {
        background: rgba(231, 76, 60, 0.1) !important;
      }
      .path-bar-error {
        color: #e74c3c;
        font-size: 12px;
        text-align: center;
        padding: 4px 0 0 0;
      }

      /* ── 路径栏响应式 ── */
      @media (max-width: 640px) {
        #path-bar {
          padding: 8px 8px;
        }
        .path-bar-row {
          gap: 4px;
        }
        .path-search-wrap {
          min-width: 80px;
          max-width: none;
          flex: 1 1 40%;
        }
        .path-search-wrap input {
          height: 36px;
          font-size: 14px;
        }
        .path-bar-icon {
          display: none;
        }
        .path-nav-btn {
          height: 36px;
          padding: 0 8px;
          font-size: 13px;
        }
      }
      @media (max-width: 480px) {
        .path-bar-row {
          flex-wrap: wrap;
        }
        .path-search-wrap {
          flex: 1 1 100%;
          min-width: 0;
        }
        .path-arrow {
          display: none;
        }
      }

      /* ── JS 动态面板响应式 ── */
      /* 邻接面板桌面端默认 */
      #neighbor-panel {
        --np-right: 0px;
        --np-top: 50%;
        --np-transform: translateY(-50%);
        --np-width: var(--neighbor-panel-width, 280px);
        --np-max-height: 75vh;
        --np-border-radius: 8px 0 0 8px;
        --np-bottom: auto;
        --np-left: auto;
      }
      /* 控制面板桌面端默认 */
      #graph-control-panel {
        --cp-bottom: 70px;
        --cp-right: 16px;
        --cp-left: auto;
        --cp-top: auto;
        --cp-width: auto;
        --cp-border-radius: 8px;
        --cp-transform: none;
      }
      /* 飞船面板桌面端默认 */
      #fly-control-panel {
        --fp-bottom: 70px;
        --fp-left: 16px;
        --fp-right: auto;
        --fp-top: auto;
        --fp-max-width: 220px;
      }
      @media (max-width: 640px) {
        #neighbor-panel {
          --np-right: 0;
          --np-top: auto;
          --np-transform: none;
          --np-bottom: 0;
          --np-left: 0;
          --np-width: 100%;
          --np-max-height: 60vh;
          --np-border-radius: 12px 12px 0 0;
        }
        #graph-control-panel {
          --cp-bottom: 0;
          --cp-right: 0;
          --cp-left: 0;
          --cp-width: 100%;
          --cp-border-radius: 12px 12px 0 0;
        }
        #fly-control-panel {
          --fp-bottom: 0;
          --fp-left: 0;
          --fp-right: 0;
          --fp-max-width: none;
          --fp-width: 100%;
          --fp-border-radius: 12px 12px 0 0;
        }
      }
      @media (min-width: 641px) and (max-width: 1024px) {
        #neighbor-panel {
          --np-width: 220px;
        }
      }
    </style>
    <script>
      import "../scripts/index-client.ts";
    </script>
    <script lang="js">
      (function () {
        // 启用暗色模式（若无系统偏好则默认为暗色）
        if (!localStorage.getItem("colorTheme")) {
          document.documentElement.classList.add("dark");
        }

        // ── 统计弹窗：点击触发时加载数据 ──
        const statsContent = document.getElementById("stats-content");

        if (statsContent) {
          const statsTrigger = document.querySelector('[data-dialog-for="stats-dialog"]');
          if (statsTrigger) {
            statsTrigger.addEventListener("click", () => {
              statsContent.innerHTML = '<div class="flex items-center justify-center py-10 text-muted-foreground text-sm">加载中...</div>';
              fetch("/stats.json")
                .then(r => r.ok ? r.json() : Promise.reject())
                .then(data => { statsContent.innerHTML = renderStatsCards(data); })
                .catch(() => { statsContent.innerHTML = '<div class="text-destructive text-sm text-center py-10">加载失败</div>'; });
            });
          }
        }

	        function renderStatsCards(data) {
	          const sd = data.sixDegrees;
	          const dist = sd?.edgeDistanceDistribution || {};
	          const entries = Object.entries(dist).filter(([d]) => Number(d) <= 20).sort(([a],[b])=>Number(a)-Number(b));
	          const maxVal = Math.max(...entries.map(([,c])=>Number(c)), 1);
	          const cd = sd?.compSizeDistribution || [];
	          const maxCompCnt = Math.max(...cd.map(b => b.count), 1);

	          const coreCnt = data.coreNodes.count;
	          const friendCnt = data.friendNodes.count;
	          const totalNodes = data.overview.totalNodes;
	          const ccBi = data.connections.coreToCore.bidirectional;
	          const ccUni = data.connections.coreToCore.unidirectional;
	          const cf = data.connections.coreToFriend;
	          const totalLinks = data.connections.total;

	          return `
	            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
	              <div class="rounded-lg border p-4">
	                <h3 class="mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">📦 节点组成</h3>
	                <div class="space-y-2">
	                  <div class="flex justify-between"><span class="text-muted-foreground text-sm">主站节点 <span class="text-xs opacity-60">(已注册)</span></span><span class="font-bold">${coreCnt.toLocaleString()}</span></div>
	                  <div class="flex justify-between"><span class="text-muted-foreground text-sm">友链节点 <span class="text-xs opacity-60">(外部引用)</span></span><span class="font-bold">${friendCnt.toLocaleString()}</span></div>
	                  <div class="border-t pt-2 flex justify-between"><span class="text-sm font-semibold">全部节点</span><span class="font-bold">${totalNodes.toLocaleString()}</span></div>
	                </div>
	              </div>
	              <div class="rounded-lg border p-4">
	                <h3 class="mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">🔀 链接方向 <span class="text-xs opacity-60">(主站间)</span></h3>
	                <div class="space-y-2">
	                  <div class="flex justify-between"><span class="text-muted-foreground text-sm">🔄 双向链接 <span class="text-xs opacity-60">(互相添加)</span></span><span class="font-bold">${ccBi.toLocaleString()} 对</span></div>
	                  <div class="flex justify-between"><span class="text-muted-foreground text-sm">➡️ 单向链接 <span class="text-xs opacity-60">(仅一方添加)</span></span><span class="font-bold">${ccUni.toLocaleString()} 对</span></div>
	                </div>
	              </div>
	              <div class="rounded-lg border p-4">
	                <h3 class="mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">📊 链接规模</h3>
	                <div class="space-y-2">
	                  <div class="flex justify-between"><span class="text-muted-foreground text-sm">↔️ 主站间</span><span class="font-bold">${(ccBi + ccUni).toLocaleString()} 条</span></div>
	                  <div class="flex justify-between"><span class="text-muted-foreground text-sm">➡️ 主站→友链</span><span class="font-bold">${cf.toLocaleString()} 条</span></div>
	                  <div class="border-t pt-2 flex justify-between"><span class="text-sm font-semibold">全部链接</span><span class="font-bold">${totalLinks.toLocaleString()} 条</span></div>
	                </div>
	              </div>
              <div class="rounded-lg border p-4 sm:col-span-2 lg:col-span-2">
                <h3 class="mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">🌐 六度分隔 · 主分量 ${sd?.mainComponentSize.toLocaleString()} 节点 · 最大 ${sd?.maxEdgeDistance} 度</h3>
                <div class="space-y-1">
                  ${entries.map(([d,c]) => {
                    const w = Math.max(1, Number(c)/maxVal*100).toFixed(0);
                    return `<div class="flex items-center gap-2 text-xs">
                      <span class="w-10 text-right text-muted-foreground shrink-0">${d}度</span>
                      <span class="h-3 rounded-sm" style="width:${w}%;background:linear-gradient(90deg,#4a9eff,#00c6ff);min-width:2px"></span>
                      <span class="text-muted-foreground shrink-0">${Number(c).toLocaleString()}</span>
                    </div>`;
                  }).join('')}
                </div>
              </div>
              ${cd.length ? `<div class="rounded-lg border p-4 sm:col-span-2 lg:col-span-2">
                <h3 class="mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">🧩 连通分量 · ${sd?.componentCount} 个 · 主分量 ${sd?.mainComponentSize.toLocaleString()} 节点</h3>
                <div class="space-y-1">
                  ${cd.map(b => {
                    const w = Math.max(1, b.count/maxCompCnt*100).toFixed(0);
                    return `<div class="flex items-center gap-2 text-xs">
                      <span class="w-12 text-right text-muted-foreground shrink-0">${b.label}</span>
                      <span class="h-3 rounded-sm" style="width:${w}%;background:linear-gradient(90deg,#4a9eff,#00c6ff);min-width:2px"></span>
                      <span class="text-muted-foreground shrink-0">${b.count.toLocaleString()}</span>
                    </div>`;
                  }).join('')}
                </div>
              </div>` : ''}
	              <div class="rounded-lg border p-4 sm:col-span-2 lg:col-span-2">
	                <h3 class="mb-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider">🚏 路由排行</h3>
	                <div class="space-y-1">
                  ${(data.linkRoutes || []).map(r => `
                    <div class="flex justify-between text-sm"><span class="text-muted-foreground">${r.route}</span><span class="font-bold">${r.count}</span></div>
                  `).join('')}
                </div>
              </div>
            </div>
          `;
        }

        // 控制面板按钮
        const opacityBtn = document.getElementById("opacity-toggle");
        if (opacityBtn) {
          opacityBtn.addEventListener("click", () => {
            const toggle = window.__toggleOpacityPanel;
            if (typeof toggle === "function") {
              toggle();
            }
          });
	        }

	        // 飞船模式切换
	        const flyBtn = document.getElementById("fly-toggle");
	        if (flyBtn) {
	          flyBtn.addEventListener("click", () => {
	            const api = window.__graphApi;
	            if (api && api.toggleFlightMode) {
	              const isFly = api.toggleFlightMode();
	              flyBtn.textContent = isFly ? "🌐 球幕模式" : "🚀 飞船模式";
	            }
	          });
	        }

	        // 全屏模式切换
	        const fsBtn = document.getElementById("fullscreen-toggle");
	        if (fsBtn) {
	          let fsEscTimes = 0, fsEscTimer = null;
	          fsBtn.addEventListener("click", () => {
	            if (!document.fullscreenElement) {
	              document.documentElement.requestFullscreen().catch(() => {});
	              fsBtn.textContent = "⛶ 退出全屏";
	            } else {
	              document.exitFullscreen().catch(() => {});
	              fsBtn.textContent = "⛶ 全屏模式";
	            }
	          });
	          document.addEventListener("fullscreenchange", () => {
	            fsBtn.textContent = document.fullscreenElement ? "⛶ 退出全屏" : "⛶ 全屏模式";
	          });
	          // ESC 退出全屏（飞船模式下不拦截，飞船模式 X 键退出）
	          document.addEventListener("keydown", (e) => {
	            if (e.key === "Escape" && document.fullscreenElement && !document.pointerLockElement) {
	              const now = Date.now();
	              if (now - fsEscTimes < 600) {
	                document.exitFullscreen().catch(() => {});
	                fsEscTimes = 0;
	                if (fsEscTimer) { clearTimeout(fsEscTimer); fsEscTimer = null; }
	              } else {
	                fsEscTimes = now;
	                fsEscTimer = setTimeout(() => { fsEscTimes = 0; fsEscTimer = null; }, 600);
	              }
	            }
	          });
	        }

	        // ── 路径查找底部栏 ──────────────────────────────────────────
        const pathBar = document.getElementById("path-bar");
        const pathToggleBtn = document.getElementById("path-toggle");
        const pathFromInput = document.getElementById("path-search-from");
        const pathToInput = document.getElementById("path-search-to");
        const pathFromResults = document.getElementById("path-results-from");
        const pathToResults = document.getElementById("path-results-to");
        const pathStepIndicator = document.getElementById("path-step-indicator");
        const pathPrevBtn = document.getElementById("path-prev-btn");
        const pathNextBtn = document.getElementById("path-next-btn");
        const pathClearBtn = document.getElementById("path-clear-btn");
        const pathBarClose = document.getElementById("path-bar-close");
        const pathError = document.getElementById("path-error");

        let selectedFrom = null; // { id, name, url }
        let selectedTo = null;

        const getApi = () => window.__graphApi || {};

        const showPathBar = () => {
          if (pathBar) {
            pathBar.classList.add("show");
            if (pathFromInput) pathFromInput.focus();
          }
        };
        const hidePathBar = () => {
          // 仅隐藏底部栏，不清除路径高亮
          if (pathBar) pathBar.classList.remove("show");
        };
        const clearPathSelections = () => {
          selectedFrom = null;
          selectedTo = null;
          if (pathFromInput) { pathFromInput.value = ""; }
          if (pathToInput) { pathToInput.value = ""; }
          if (pathFromResults) { pathFromResults.style.display = "none"; pathFromResults.innerHTML = ""; }
	          if (pathToResults) { pathToResults.style.display = "none"; pathToResults.innerHTML = ""; }
	          if (pathStepIndicator) { pathStepIndicator.style.display = "none"; }
	          if (pathClearBtn) { pathClearBtn.style.display = "none"; }
	          if (pathError) { pathError.style.display = "none"; }
          const api = getApi();
          if (api.clearPath) api.clearPath();
        };

        // 切换按钮
        if (pathToggleBtn) {
          pathToggleBtn.addEventListener("click", () => {
            if (pathBar && pathBar.classList.contains("show")) {
              hidePathBar();
            } else {
              showPathBar();
            }
          });
        }
        // 关闭按钮 — 仅隐藏，不清除
        if (pathBarClose) {
          pathBarClose.addEventListener("click", hidePathBar);
        }

        // 搜索结果渲染
        const renderPathResults = (container, list, onSelect) => {
          container.innerHTML = "";
          if (!list || !list.length) {
            container.style.display = "none";
            return;
          }
          for (let i = 0; i < Math.min(list.length, 8); i++) {
            const it = list[i];
            const el = document.createElement("div");
            el.className = "path-result-item";
            el.innerHTML = `<div class="path-result-name">${it.name}</div>
              <div class="path-result-url">${it.url || ""}</div>`;
            el.addEventListener("click", () => {
              onSelect(it);
              container.style.display = "none";
            });
            container.appendChild(el);
          }
          container.style.display = "block";
        };

        // 起点搜索
        if (pathFromInput) {
          pathFromInput.addEventListener("input", () => {
            const v = pathFromInput.value.trim();
            if (!v) { pathFromResults.style.display = "none"; return; }
            const api = getApi();
            const list = api.find ? api.find(v) : [];
            renderPathResults(pathFromResults, list, (item) => {
              selectedFrom = item;
              pathFromInput.value = item.name;
              checkBothSelected();
            });
          });
        }

        // 终点搜索
        if (pathToInput) {
          pathToInput.addEventListener("input", () => {
            const v = pathToInput.value.trim();
            if (!v) { pathToResults.style.display = "none"; return; }
            const api = getApi();
            const list = api.find ? api.find(v) : [];
            renderPathResults(pathToResults, list, (item) => {
              selectedTo = item;
              pathToInput.value = item.name;
              checkBothSelected();
            });
          });
        }

        // 两个站点都选定后自动计算路径
        const checkBothSelected = () => {
          if (!selectedFrom || !selectedTo) return;
          const api = getApi();
          if (!api.showShortestPath) return;

          // 边界条件：起点终点相同
          if (selectedFrom.id === selectedTo.id) {
            pathError.textContent = "起点和终点相同，请选择两个不同的节点";
            pathError.style.display = "block";
            pathStepIndicator.style.display = "none";
            pathClearBtn.style.display = "none";
            return;
          }

          const path = api.showShortestPath(selectedFrom.id, selectedTo.id);
          if (!path || !path.length) {
            pathError.textContent = `未找到从 ${selectedFrom.name} 到 ${selectedTo.name} 的路径`;
            pathError.style.display = "block";
            pathStepIndicator.style.display = "none";
            pathClearBtn.style.display = "none";
            return;
          }

          pathError.style.display = "none";
          pathStepIndicator.style.display = "inline";
          pathClearBtn.style.display = "inline-flex";
          updatePathUI();
        };

        const updatePathUI = () => {
          const api = getApi();
          const info = api.getPathInfo ? api.getPathInfo() : null;
          if (!info) return;

          pathStepIndicator.textContent = `${info.currentStep + 1}/${info.totalSteps} 步`;
          pathPrevBtn.disabled = info.currentStep <= 0;
          pathNextBtn.disabled = info.currentStep >= info.totalSteps - 1;
        };

        // 步进按钮
        if (pathPrevBtn) {
          pathPrevBtn.addEventListener("click", () => {
            const api = getApi();
            if (api.stepPathPrev) {
              api.stepPathPrev();
              updatePathUI();
            }
          });
        }
        if (pathNextBtn) {
          pathNextBtn.addEventListener("click", () => {
            const api = getApi();
            if (api.stepPathNext) {
              api.stepPathNext();
              updatePathUI();
            }
          });
        }

        // 清除路径按钮
        if (pathClearBtn) {
          pathClearBtn.addEventListener("click", () => {
            clearPathSelections();
          });
        }

        // 点击外部关闭搜索结果
        document.addEventListener("click", (e) => {
          if (pathFromInput && pathFromResults && !pathFromInput.contains(e.target) && !pathFromResults.contains(e.target)) {
            pathFromResults.style.display = "none";
          }
          if (pathToInput && pathToResults && !pathToInput.contains(e.target) && !pathToResults.contains(e.target)) {
            pathToResults.style.display = "none";
          }
        });

        // ESC 关闭底部栏（不清除路径）
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && pathBar && pathBar.classList.contains("show")) {
            hidePathBar();
          }
        });
      })();
    </script>
  </body>
</html>
