---
import "../css/base.css";
import "../css/topbar.css";
import "../css/buttons.css";
import "../css/modal.css";
	export const prerender = true;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/StreamlinePlumpColorWebFlat.svg"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>友链图谱</title>
  </head>
  <body>
    <div class="topbar">
      <div class="title" style="font-weight:600; padding-left:6px;">
        <span>友链图谱</span>
        <a
          class="github-link"
          href="https://github.com/xingwangzhe/FriendLinks"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open GitHub repository"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 16 16"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.19 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path>
          </svg>
        </a>
      </div>
      <div class="search">
        <input
          id="graph-search"
          type="text"
          placeholder="搜索站点名或域名 | 左键打开网站 | 右键聚焦节点"
          autocomplete="off"
        />
        <button id="graph-search-clear" class="search-clear" aria-label="清空搜索" title="清空搜索">✖</button>
        <div id="graph-search-results" class="results" role="listbox"></div>
      </div>
    </div>
    <div id="main"></div>

    <!-- 首屏加载蒙版 -->
    <div id="loading-overlay">
      <div class="loading-box">
        <div class="loading-spinner"></div>
        <div class="loading-status">
          <span id="loading-text">正在加载友链数据...</span>
          <span id="loading-time" class="loading-time"></span>
        </div>
        <div class="loading-bar-track">
          <div id="loading-bar" class="loading-bar-fill"></div>
        </div>
      </div>
    </div>

    <div class="top-buttons">
      <button id="fly-toggle" class="top-button" aria-label="切换飞船模式"
        >🚀 飞船模式</button
      >
      <button id="about-toggle" class="top-button" aria-label="关于项目"
        >关于</button
      >
      <button id="stats-toggle" class="top-button" aria-label="查看统计信息"
        >📊友链统计</button
      >
      <button id="opacity-toggle" class="top-button" aria-label="连线透明度设置"
        >连线设置</button
      >
      <button id="path-toggle" class="top-button" aria-label="路径查找"
        >🔗 路径查找</button
      >
    </div>

    <!-- 统计弹窗 -->
    <div id="stats-modal" role="dialog" aria-modal="true">
      <div class="modal-content">
        <div class="modal-header">
          <h2>📊 友链统计</h2>
          <button class="close-btn" aria-label="关闭">&times;</button>
        </div>
        <div id="stats-content">
          <div class="loading">加载中...</div>
        </div>
      </div>
    </div>
    <!-- 关于弹窗 -->
    <div id="about-modal" role="dialog" aria-modal="true">
      <div class="modal-content">
        <div class="modal-header">
          <h2>关于 FriendLinks</h2>
          <button class="close-btn" aria-label="关闭">&times;</button>
        </div>
        <div class="about-content">
          <h3>友链图谱</h3>
          <p><strong>法律合规说明：</strong>网站所有者和投稿者必须确保其发布内容及网站运营遵守中华人民共和国以及适用情况下的美利坚合众国法律法规（包括但不限于版权、隐私、网络安全与信息内容方面的法律）。</p>
          <p><strong>请确保：</strong>你的站点使用 <code>https</code> 并可以在大陆访问。</p>
          <h4>操作说明</h4>
          <ul>
            <li><strong>左键点击节点</strong>：在新标签页打开对应网站</li>
            <li><strong>右键点击节点</strong>：聚焦该节点（相机拉近、节点放大 1.5 倍、金色粗管荧光连线），右侧弹出邻居节点面板</li>
            <li><strong>悬停节点</strong>：显示站点名称/描述/链接，白色荧光连线</li>
            <li><strong>鼠标拖拽</strong>：旋转 3D 视角</li>
            <li><strong>滚轮</strong>：缩放视图</li>
            <li><strong>搜索框</strong>：模糊搜索站点名或域名</li>
            <li><strong>「连线设置」按钮</strong>：调整基础线网透明度</li>
          </ul>
          <h4>聚焦效果说明</h4>
          <p>右键点击节点后，会触发以下视觉效果：</p>
          <ul>
            <li>节点半径<strong>放大 1.5 倍</strong></li>
            <li>节点颜色<strong>调亮 60%</strong></li>
            <li>相连连线变为<strong>亮金色粗管</strong>，带荧光光晕</li>
            <li>相机自动将节点移动到视野中心</li>
            <li>邻居节点轻微高亮（调亮 20%）</li>
          </ul>
          <h4>添加你的博客</h4>
          <p>在 <code>links/&#123;yoursite&#125;.yml</code> 中填写你的站点信息，示例格式如下：</p>
          <pre><code class="yaml">site:
  name: 我的博客
  description: 分享编程和技术相关的文章
  url: https://example.com
  color: "#ff6600"  # 可选，自定义节点颜色
  links: /links     # 友链页面路由（必填）
  friends:
    - name: 编程小站
      url: https://codehub.example.com</code></pre>
          <h4>URL 聚焦查询（自动高亮）</h4>
          <p>通过在页面地址中添加 <code>?local=域名</code> 参数即可自动定位到指定节点。</p>
          <ul>
            <li><code>?local=example.com</code> — 按域名匹配</li>
            <li><code>?local=https://example.com</code> — 按完整 URL 匹配</li>
          </ul>
          <h4>如何贡献</h4>
          <ol>
            <li>Fork 本仓库并创建新分支用于改动。</li>
            <li>在 <code>links/</code> 下添加或更新你的 <code>blog.yml</code> 文件，<strong>必须填写 <code>links</code> 字段</strong>（友链页面路由如 <code>/links</code>、<code>/link</code>、<code>/friends</code> 等），可选的 <code>color</code> 字段可自定义节点颜色。</li>
            <li>提交改动并提 PR，之后会审查并合并入主干。</li>
          </ol>
          <div style="margin-top: 12px; display:flex; gap:8px; flex-wrap:wrap;">
            <a href="https://github.com/xingwangzhe/FriendLinks" target="_blank" rel="noopener" class="modal-link">查看仓库</a>
          </div>
        </div>
      </div>
    </div>
    <!-- 路径查找底部栏 -->
    <div id="path-bar" class="path-bar">
      <div class="path-bar-row">
        <span class="path-bar-icon">🔗</span>
        <div class="path-search-wrap">
          <input
            id="path-search-from"
            type="text"
            placeholder="起点站点…"
            autocomplete="off"
          />
          <div id="path-results-from" class="path-results" role="listbox"></div>
        </div>
        <span class="path-arrow">→</span>
        <div class="path-search-wrap">
          <input
            id="path-search-to"
            type="text"
            placeholder="终点站点…"
            autocomplete="off"
          />
          <div id="path-results-to" class="path-results" role="listbox"></div>
        </div>
        <span id="path-step-indicator" class="path-step-info" style="display:none;"></span>
        <button id="path-prev-btn" class="path-nav-btn" disabled title="上一步">◀</button>
        <button id="path-next-btn" class="path-nav-btn" disabled title="下一步">▶</button>
        <button id="path-clear-btn" class="path-nav-btn path-clear-btn" title="清除路径" style="display:none;">✕</button>
        <button id="path-bar-close" class="path-nav-btn" title="关闭">−</button>
      </div>
      <div id="path-error" class="path-bar-error" style="display:none;"></div>
    </div>
    <style>
      /* 顶部按钮通用样式 */
      .top-button {
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--card-bg);
        color: var(--text-color);
        cursor: pointer;
        pointer-events: auto;
        font-size: 14px;
        white-space: nowrap;
      }
      .top-button:focus {
        outline: 2px solid
          color-mix(in srgb, var(--text-color) 20%, transparent);
      }

      /* 按钮容器 */
      .top-buttons {
        position: fixed;
        top: 12px;
        right: 12px;
        z-index: 60; /* 高于 .topbar (20) 和移动端的 #theme-toggle (40) */
        display: flex;
        gap: 8px;
        pointer-events: auto;
      }

      /* 覆盖可能存在的 id 选择器定位（来自 topbar.css），确保按钮在容器内正常布局 */
      #stats-toggle {
        position: relative !important;
        top: auto !important;
        right: auto !important;
        z-index: 61 !important;
      }

      /* 移动端调整 */
      @media (max-width: 640px) {
        .top-buttons {
          top: 8px;
          right: 8px;
          gap: 6px;
        }
        .top-button {
          font-size: 12px;
          padding: 4px 8px;
        }
      }

      /* 统计弹窗样式 */
      #stats-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transition:
          opacity 0.3s ease,
          visibility 0.3s ease;
      }
      #stats-modal.show {
        opacity: 1;
        visibility: visible;
      }
      #stats-modal .modal-content {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        position: relative;
        transform: translateY(-20px);
        transition: transform 0.3s ease;
        margin: 20px; /* 在小屏幕上添加边距 */
      }
      #stats-modal.show .modal-content {
        transform: translateY(0);
      }
      #stats-modal .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border);
      }
      #stats-modal .modal-header h2 {
        margin: 0;
        color: var(--text-color);
        font-size: 18px;
      }
      #stats-modal .close-btn {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: var(--text-color);
        padding: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      #stats-modal .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
      }
      #stats-modal .stat-item {
        background: color-mix(in srgb, var(--card-bg) 95%, black 5%);
        padding: 15px;
        border-radius: 6px;
        text-align: center;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60px;
      }
      #stats-modal .stat-label {
        font-size: 14px;
        color: var(--muted);
        font-weight: 500;
        line-height: 1.2;
      }
      #stats-modal .stat-value {
        font-size: 18px;
        font-weight: bold;
        line-height: 1.2;
        color: var(--accent);
      }

      /* 暗色主题下 stat-value 颜色跟随 accent */
      #stats-modal .loading {
        text-align: center;
        color: var(--muted);
        padding: 40px;
      }
      #stats-modal .error {
        text-align: center;
        color: var(--danger);
        padding: 40px;
      }
      #stats-modal .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 20px;
      }
      #stats-modal .stat-section {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
      }
      #stats-modal .stat-section h3 {
        margin: 0 0 12px 0;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-color);
        border-bottom: 1px solid var(--border);
        padding-bottom: 8px;
      }

      /* 移动端响应式 */
      @media (max-width: 640px) {
        #stats-modal .modal-content {
          width: calc(100% - 40px);
          margin: 20px;
          padding: 15px;
          max-height: 90vh;
        }
        #stats-modal .stats-grid {
          grid-template-columns: 1fr;
          gap: 15px;
        }
        #stats-modal .stat-section {
          padding: 12px;
        }
        #stats-modal .stat-section h3 {
          font-size: 13px;
          margin-bottom: 10px;
        }
        #stats-modal .stat-item {
          padding: 12px;
          min-height: 50px;
        }
        #stats-modal .stat-label {
          font-size: 13px;
        }
        #stats-modal .stat-value {
          font-size: 16px;
        }
        #stats-modal .modal-header h2 {
          font-size: 16px;
        }
      }

      /* 首屏加载蒙版 */
      #loading-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg, #0f1115);
        transition: opacity 0.5s ease;
      }
      #loading-overlay.hidden {
        opacity: 0;
        pointer-events: none;
      }
      .loading-box {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
      }
      .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid var(--border);
        border-top-color: #4a9eff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      .loading-status {
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: center;
      }
      .loading-status span {
        font-size: 14px;
        color: var(--muted);
        font-family: sans-serif;
      }
      .loading-time {
        font-size: 12px !important;
        color: var(--muted) !important;
        font-variant-numeric: tabular-nums;
      }
      .loading-bar-track {
        width: 200px;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
      }
      .loading-bar-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #4a9eff, #7c5cfc);
        border-radius: 2px;
        transition: width 0.3s ease;
      }

      /* 路径底部栏 */
      #path-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: var(--card-bg);
        border-top: 1px solid var(--border);
        box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.12);
        padding: 8px 16px;
        transform: translateY(100%);
        transition: transform 0.3s ease;
      }
      #path-bar.show {
        transform: translateY(0);
      }
      .path-bar-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .path-bar-icon {
        font-size: 16px;
        flex-shrink: 0;
      }
      .path-arrow {
        color: var(--muted);
        font-size: 14px;
        flex-shrink: 0;
      }
      .path-search-wrap {
        position: relative;
        flex: 1;
        min-width: 120px;
        max-width: 220px;
      }
      .path-search-wrap input {
        width: 100%;
        height: 32px;
        padding: 0 8px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--card-bg);
        color: var(--text-color);
        font-size: 13px;
        box-sizing: border-box;
      }
      .path-search-wrap input:focus {
        outline: 2px solid color-mix(in srgb, var(--text-color) 20%, transparent);
      }
      .path-results {
        position: absolute;
        bottom: 100%;
        left: 0;
        right: 0;
        max-height: 200px;
        overflow-y: auto;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 6px;
        box-shadow: 0 -6px 18px rgba(0, 0, 0, 0.12);
        display: none;
        z-index: 10;
        margin-bottom: 4px;
      }
      .path-results .path-result-item {
        padding: 6px 10px;
        cursor: pointer;
        font-size: 13px;
        color: var(--text-color);
      }
      .path-results .path-result-item:hover {
        background: color-mix(in srgb, var(--card-bg) 92%, black 8%);
      }
      .path-result-item .path-result-name {
        font-weight: 600;
      }
      .path-result-item .path-result-url {
        font-size: 11px;
        color: var(--muted);
        margin-top: 2px;
      }
      .path-step-info {
        font-size: 12px;
        color: var(--muted);
        white-space: nowrap;
        flex-shrink: 0;
      }
      .path-nav-btn {
        height: 32px;
        padding: 0 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--card-bg);
        color: var(--text-color);
        cursor: pointer;
        font-size: 14px;
        flex-shrink: 0;
        white-space: nowrap;
      }
      .path-nav-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }
      .path-nav-btn:not(:disabled):hover {
        background: color-mix(in srgb, var(--card-bg) 92%, black 8%);
      }
      .path-clear-btn {
        color: #e74c3c;
        border-color: #e74c3c;
      }
      .path-clear-btn:hover {
        background: rgba(231, 76, 60, 0.1) !important;
      }
      .path-bar-error {
        color: #e74c3c;
        font-size: 12px;
        text-align: center;
        padding: 4px 0 0 0;
      }
    </style>
    <script>
      import "../scripts/index-client.ts";
    </script>
    <script lang="js">
      (function () {
        // 强制暗色宇宙模式
        document.documentElement.dataset.theme = "dark";

        // 统计弹窗功能
        const statsBtn = document.getElementById("stats-toggle");
        const statsModal = document.getElementById("stats-modal");
        const statsContent = document.getElementById("stats-content");
        const closeBtn = statsModal?.querySelector(".close-btn");

        const showStatsModal = () => {
          if (!statsModal) return;
          statsModal.classList.add("show");
          loadStatsData();
        };

        const hideStatsModal = () => {
          if (!statsModal) return;
          statsModal.classList.remove("show");
        };

        const loadStatsData = () => {
          if (!statsContent) return;

          statsContent.innerHTML = '<div class="loading">加载中...</div>';

          fetch("/stats.json")
            .then((response) => {
              if (!response.ok) {
                throw new Error("网络请求失败");
              }
              return response.json();
            })
            .then((data) => {
              renderStats(data);
            })
            .catch((error) => {
              console.error("加载统计数据失败:", error);
              statsContent.innerHTML =
                '<div class="error">加载失败，请稍后重试</div>';
            });
        };

        const renderStats = (data) => {
          if (!statsContent) return;

          const statsHtml = `
            <div class="stats-grid">
              <div class="stat-section">
                <h3>核心节点</h3>
                <div class="stat-item">
                  <span class="stat-label">核心节点数</span>
                  <span class="stat-value">${data.coreNodes.count}</span>
                </div>
                <div class="stat-item">
                  <span class="stat-label">唯一域名</span>
                  <span class="stat-value">${data.coreNodes.uniqueHosts}</span>
                </div>
              </div>

              <div class="stat-section">
                <h3>友链节点</h3>
                <div class="stat-item">
                  <span class="stat-label">友链节点总数</span>
                  <span class="stat-value">${data.friendNodes.total}</span>
                </div>
                <div class="stat-item">
                  <span class="stat-label">外部友链</span>
                  <span class="stat-value">${data.friendNodes.externalFriends}</span>
                </div>
              </div>

              <div class="stat-section">
                <h3>核心节点间连接</h3>
                <div class="stat-item">
                  <span class="stat-label">连接总数</span>
                  <span class="stat-value">${data.connections.coreToCore.total}</span>
                </div>
                <div class="stat-item">
                  <span class="stat-label">双向连接</span>
                  <span class="stat-value">${data.connections.coreToCore.bidirectional}</span>
                </div>
                <div class="stat-item">
                  <span class="stat-label">单向连接</span>
                  <span class="stat-value">${data.connections.coreToCore.unidirectional}</span>
                </div>
              </div>

              <div class="stat-section">
                <h3>核心节点到友链</h3>
                <div class="stat-item">
                  <span class="stat-label">连接数量</span>
                  <span class="stat-value">${data.connections.coreToFriend}</span>
                </div>
              </div>

              <div class="stat-section">
                <h3>总览</h3>
                <div class="stat-item">
                  <span class="stat-label">所有节点数</span>
                  <span class="stat-value">${data.overview.totalNodes}</span>
                </div>
                <div class="stat-item">
                  <span class="stat-label">总连接数</span>
                  <span class="stat-value">${data.overview.totalConnections}</span>
                </div>
              </div>

              <div class="stat-section">
                <h3>友链页面路由排行</h3>
                ${(data.linkRoutes || []).map(r => `
                  <div class="stat-item">
                    <span class="stat-label">${r.route}</span>
                    <span class="stat-value">${r.count}</span>
                  </div>
                `).join('')}
              </div>
            </div>
          `;

          statsContent.innerHTML = statsHtml;
        }

        if (statsBtn) {
          statsBtn.addEventListener("click", showStatsModal);
        }

        if (closeBtn) {
          closeBtn.addEventListener("click", hideStatsModal);
        }

        if (statsModal) {
          statsModal.addEventListener("click", (e) => {
            if (e.target === statsModal) {
              hideStatsModal();
            }
          });
        }

        // About modal
        const aboutBtn = document.getElementById("about-toggle");
        const aboutModal = document.getElementById("about-modal");
        const aboutClose = aboutModal?.querySelector(".close-btn");

        const showAboutModal = () => {
          if (!aboutModal) return;
          aboutModal.classList.add("show");
        };

        const hideAboutModal = () => {
          if (!aboutModal) return;
          aboutModal.classList.remove("show");
        };

        if (aboutBtn) {
          aboutBtn.addEventListener("click", showAboutModal);
        }

        if (aboutClose) {
          aboutClose.addEventListener("click", hideAboutModal);
        }

        if (aboutModal) {
          aboutModal.addEventListener("click", (e) => {
            if (e.target === aboutModal) {
              hideAboutModal();
            }
          });
        }

        // ESC键关闭弹窗（关闭任一显示的弹窗）
        document.addEventListener("keydown", (e) => {
          if (e.key !== "Escape") return;
          if (statsModal?.classList.contains("show")) hideStatsModal();
          if (aboutModal?.classList.contains("show")) hideAboutModal();
        });

        // 连线设置面板按钮
        const opacityBtn = document.getElementById("opacity-toggle");
        if (opacityBtn) {
          opacityBtn.addEventListener("click", () => {
            const toggle = window.__toggleOpacityPanel;
            if (typeof toggle === "function") {
              toggle();
            }
          });
	        }

	        // 飞船模式切换
	        const flyBtn = document.getElementById("fly-toggle");
	        if (flyBtn) {
	          flyBtn.addEventListener("click", () => {
	            const api = window.__graphApi as any;
	            if (api && api.toggleFlightMode) {
	              const isFly = api.toggleFlightMode();
	              flyBtn.textContent = isFly ? "🌐 球幕模式" : "🚀 飞船模式";
	            }
	          });
	        }

	        // ── 路径查找底部栏 ──────────────────────────────────────────
        const pathBar = document.getElementById("path-bar");
        const pathToggleBtn = document.getElementById("path-toggle");
        const pathFromInput = document.getElementById("path-search-from");
        const pathToInput = document.getElementById("path-search-to");
        const pathFromResults = document.getElementById("path-results-from");
        const pathToResults = document.getElementById("path-results-to");
        const pathStepIndicator = document.getElementById("path-step-indicator");
        const pathPrevBtn = document.getElementById("path-prev-btn");
        const pathNextBtn = document.getElementById("path-next-btn");
        const pathClearBtn = document.getElementById("path-clear-btn");
        const pathBarClose = document.getElementById("path-bar-close");
        const pathError = document.getElementById("path-error");

        let selectedFrom = null; // { id, name, url }
        let selectedTo = null;

        const getApi = () => window.__graphApi || {};

        const showPathBar = () => {
          if (pathBar) {
            pathBar.classList.add("show");
            if (pathFromInput) pathFromInput.focus();
          }
        };
        const hidePathBar = () => {
          // 仅隐藏底部栏，不清除路径高亮
          if (pathBar) pathBar.classList.remove("show");
        };
        const clearPathSelections = () => {
          selectedFrom = null;
          selectedTo = null;
          if (pathFromInput) { pathFromInput.value = ""; }
          if (pathToInput) { pathToInput.value = ""; }
          if (pathFromResults) { pathFromResults.style.display = "none"; pathFromResults.innerHTML = ""; }
          if (pathToResults) { pathToResults.style.display = "none"; pathToResults.innerHTML = ""; }
          if (pathStepIndicator) pathStepIndicator.style.display = "none";
          if (pathClearBtn) pathClearBtn.style.display = "none";
          if (pathError) pathError.style.display = "none";
          const api = getApi();
          if (api.clearPath) api.clearPath();
        };

        // 切换按钮
        if (pathToggleBtn) {
          pathToggleBtn.addEventListener("click", () => {
            if (pathBar && pathBar.classList.contains("show")) {
              hidePathBar();
            } else {
              showPathBar();
            }
          });
        }
        // 关闭按钮 — 仅隐藏，不清除
        if (pathBarClose) {
          pathBarClose.addEventListener("click", hidePathBar);
        }

        // 搜索结果渲染
        const renderPathResults = (container, list, onSelect) => {
          container.innerHTML = "";
          if (!list || !list.length) {
            container.style.display = "none";
            return;
          }
          for (let i = 0; i < Math.min(list.length, 8); i++) {
            const it = list[i];
            const el = document.createElement("div");
            el.className = "path-result-item";
            el.innerHTML = `<div class="path-result-name">${it.name}</div>
              <div class="path-result-url">${it.url || ""}</div>`;
            el.addEventListener("click", () => {
              onSelect(it);
              container.style.display = "none";
            });
            container.appendChild(el);
          }
          container.style.display = "block";
        };

        // 起点搜索
        if (pathFromInput) {
          pathFromInput.addEventListener("input", () => {
            const v = pathFromInput.value.trim();
            if (!v) { pathFromResults.style.display = "none"; return; }
            const api = getApi();
            const list = api.find ? api.find(v) : [];
            renderPathResults(pathFromResults, list, (item) => {
              selectedFrom = item;
              pathFromInput.value = item.name;
              checkBothSelected();
            });
          });
        }

        // 终点搜索
        if (pathToInput) {
          pathToInput.addEventListener("input", () => {
            const v = pathToInput.value.trim();
            if (!v) { pathToResults.style.display = "none"; return; }
            const api = getApi();
            const list = api.find ? api.find(v) : [];
            renderPathResults(pathToResults, list, (item) => {
              selectedTo = item;
              pathToInput.value = item.name;
              checkBothSelected();
            });
          });
        }

        // 两个站点都选定后自动计算路径
        const checkBothSelected = () => {
          if (!selectedFrom || !selectedTo) return;
          const api = getApi();
          if (!api.showShortestPath) return;

          // 边界条件：起点终点相同
          if (selectedFrom.id === selectedTo.id) {
            pathError.textContent = "起点和终点相同，请选择两个不同的节点";
            pathError.style.display = "block";
            pathStepIndicator.style.display = "none";
            pathClearBtn.style.display = "none";
            return;
          }

          const path = api.showShortestPath(selectedFrom.id, selectedTo.id);
          if (!path || !path.length) {
            pathError.textContent = `未找到从 ${selectedFrom.name} 到 ${selectedTo.name} 的路径`;
            pathError.style.display = "block";
            pathStepIndicator.style.display = "none";
            pathClearBtn.style.display = "none";
            return;
          }

          pathError.style.display = "none";
          pathStepIndicator.style.display = "inline";
          pathClearBtn.style.display = "inline-flex";
          updatePathUI();
        };

        const updatePathUI = () => {
          const api = getApi();
          const info = api.getPathInfo ? api.getPathInfo() : null;
          if (!info) return;

          pathStepIndicator.textContent = `${info.currentStep + 1}/${info.totalSteps} 步`;
          pathPrevBtn.disabled = info.currentStep <= 0;
          pathNextBtn.disabled = info.currentStep >= info.totalSteps - 1;
        };

        // 步进按钮
        if (pathPrevBtn) {
          pathPrevBtn.addEventListener("click", () => {
            const api = getApi();
            if (api.stepPathPrev) {
              api.stepPathPrev();
              updatePathUI();
            }
          });
        }
        if (pathNextBtn) {
          pathNextBtn.addEventListener("click", () => {
            const api = getApi();
            if (api.stepPathNext) {
              api.stepPathNext();
              updatePathUI();
            }
          });
        }

        // 清除路径按钮
        if (pathClearBtn) {
          pathClearBtn.addEventListener("click", () => {
            clearPathSelections();
          });
        }

        // 点击外部关闭搜索结果
        document.addEventListener("click", (e) => {
          if (pathFromInput && pathFromResults && !pathFromInput.contains(e.target) && !pathFromResults.contains(e.target)) {
            pathFromResults.style.display = "none";
          }
          if (pathToInput && pathToResults && !pathToInput.contains(e.target) && !pathToResults.contains(e.target)) {
            pathToResults.style.display = "none";
          }
        });

        // ESC 关闭底部栏（不清除路径）
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && pathBar && pathBar.classList.contains("show")) {
            hidePathBar();
          }
        });
      })();
    </script>
  </body>
</html>
