{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "printWidth": 120,
  "trailingComma": "all",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "ignorePatterns": ["dist/", "node_modules/", "public/scripts/"]
}
